GROQ_CLOUD_API_KEY=your_groq_api_key_here
MODEL=qwen/qwen3-32b
GROQ_BASE_URL=https://api.groq.com/openai/v1
MODEL_TEMPERATURE=0.35
MODEL_MAX_TOKENS=900
Database_url=mongodb+srv://<username>:<password>@<cluster-url>/?appName=ReWordify
MONGODB_DB_NAME=rewordify
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
AUTH_COOKIE_NAME=rewordify_token
COOKIE_SECURE=false
APP_BASE_URL=http://localhost:8000
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=no-reply@rewordify.com
SMTP_FROM_NAME=ReWordify
SMTP_USE_TLS=true
